LLM_MODEL_NAME=deepseek-v4-pro
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.1
# 模型内置搜索适配：auto / openai_responses / none
LLM_WEB_SEARCH_BACKEND=auto
READINESS_TIMEOUT_SECONDS=30

# ========== 数据源配置 ==========
# Apify API token（https://console.apify.com/account/integrations）
APIFY_API_TOKEN=
APIFY_TIMEOUT_SECONDS=300
# 是否强制使用 Mock 数据源：true / false
USE_MOCK=true
# 可选：覆盖默认 Amazon Scraper Actor ID
# APIFY_AMAZON_ACTOR_ID=automation-lab/amazon-scraper
# 可选：Amazon 搜索结果缓存；未配置或连接失败时自动跳过
MONGODB_URL=

# `category_cards` 与商品搜索缓存共用这个 MongoDB 实例。

# ========== Java 网关 ==========
LECTOR_API_KEY=
LECTOR_RATE_CAPACITY=60
LECTOR_RATE_REFILL_PER_MINUTE=60
FRONTEND_USERNAME=lector
FRONTEND_PASSWORD=

# ========== Compose MongoDB 主机端口（可选） ==========
MONGODB_HOST_PORT=27017
AGENT_HOST_PORT=8000
