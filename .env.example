LLM_MODEL_NAME=deepseek-v4-pro
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.1
# 模型内置搜索适配：auto / openai_responses / none
LLM_WEB_SEARCH_BACKEND=auto

# ========== 数据源配置 ==========
# Apify API token（https://console.apify.com/account/integrations）
APIFY_API_TOKEN=
# 是否强制使用 Mock 数据源：true / false
USE_MOCK=true
# 可选：覆盖默认 Amazon Scraper Actor ID
# APIFY_AMAZON_ACTOR_ID=automation-lab/amazon-scraper
# 可选：Amazon 搜索结果缓存；未配置或连接失败时自动跳过
MONGODB_URL=

# ========== 品类知识库（可选） ==========
OPENSEARCH_HOST=localhost
OPENSEARCH_USER=
OPENSEARCH_PASS=
TOWER_USER_ENDPOINT=http://localhost:8001/encode/user
TOWER_QUERY_ENDPOINT=http://localhost:8001/encode/query
CATEGORY_KB_INDEX=lector_category_kb
CATEGORY_KB_SEARCH_PIPELINE=lector_hybrid_pipeline
