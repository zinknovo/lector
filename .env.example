LLM_MODEL_NAME=deepseek-v4-pro
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.1

# ========== 数据源配置 ==========
# Apify API token（https://console.apify.com/account/integrations）
APIFY_API_TOKEN=
# 是否强制使用 Mock 数据源：true / false
USE_MOCK=true
# 可选：覆盖默认 Amazon Scraper Actor ID
# APIFY_AMAZON_ACTOR_ID=automation-lab/amazon-scraper
# 可选：Amazon 搜索结果缓存；未配置或连接失败时自动跳过
MONGODB_URL=
